# ─── Copy to studio/.env.local (never commit) ───
# Created when you spin up a Sanity project at https://sanity.io/manage
# The CLI uses these for `sanity deploy` and `sanity dev`.
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=staging

# Branding — shown in the Studio top-left wordmark. Per-client override.
# BRAND_IMAGE (absolute URL or /public-path) takes precedence over BRAND_EMOJI.
SANITY_STUDIO_BRAND_NAME=Studio
SANITY_STUDIO_BRAND_EMOJI=📝
SANITY_STUDIO_BRAND_IMAGE=

# Preview URL for the Presentation tool (inline iframe preview)
# Falls back to http://localhost:5173 in local dev.
SANITY_STUDIO_PREVIEW_URL=http://localhost:5173
