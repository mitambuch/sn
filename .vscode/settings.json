{
  // Formatter
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },

  // TypeScript
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.preferences.importModuleSpecifier": "non-relative",

  // Tailwind CSS IntelliSense — reconnaît cn() comme classe
  "tailwindCSS.experimental.classRegex": [
    ["cn\\(([^)]*)\\)", "'([^']*)'"],
    ["cn\\(([^)]*)\\)", "\"([^\"]*)\""],
    ["cn\\(([^)]*)\\)", "`([^`]*)`"]
  ],

  // Git — use inline input box instead of opening COMMIT_EDITMSG file
  "git.useEditorAsCommitInput": false,

  // Files
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,

  // Explorer
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.test.ts, ${capture}.spec.ts",
    "*.tsx": "${capture}.test.tsx, ${capture}.spec.tsx",
    "package.json": "pnpm-lock.yaml, .env*, .gitattributes, .gitignore, .prettierrc*, prettier.config.*, .eslintrc*, eslint.config.*, commitlint.config.*, .release-it.*, CLAUDE.md, CONTRIBUTING.md"
  },

  // Per-project accent — managed by scripts/vscode-project-color.js
  "workbench.colorCustomizations": {
    "titleBar.activeBackground": "#5a7090",
    "titleBar.activeForeground": "#f5f5f5",
    "titleBar.inactiveBackground": "#394351",
    "titleBar.inactiveForeground": "#f5f5f5",
    "statusBar.background": "#5a7090",
    "statusBar.foreground": "#f5f5f5",
    "statusBar.noFolderBackground": "#394351"
  }
}
